{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "commonjs",
		"moduleResolution": "node",
		"outDir": "./lib",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true
	},
	"include": ["src"],
	"exclude": ["dist", "node_modules", "src/**/*.test.ts"]
}
